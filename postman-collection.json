{
  "info": {
    "name": "Mock API",
    "description": "Mock API collection for mobile team",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@mock.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+6281234567892\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mock.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@mock.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?page=1&limit=10",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?search=admin",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?page=1&limit=10"
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?search=shirt&category=fashion"
          }
        },
        {
          "name": "Filter by Price",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?min_price=100000&max_price=500000&sort=price&order=asc"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"A great product\",\n  \"price\": 150000,\n  \"category\": \"electronics\",\n  \"stock\": 100\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "Read All",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/notifications/read-all",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Scenarios",
      "item": [
        {
          "name": "500 Error",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?scenario=error"
          }
        },
        {
          "name": "Empty Response",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?scenario=empty"
          }
        },
        {
          "name": "Slow Response (3s)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?scenario=slow"
          }
        },
        {
          "name": "Maintenance",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?scenario=maintenance"
          }
        },
        {
          "name": "Rate Limited",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?scenario=rate_limit"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    }
  ]
}
