# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=mock-secret-key-change-in-production

# Access token lifetime. Production target: 15m. The 7d default keeps local dev
# convenient — Dio refresh interceptors should still rely on 401 to rotate.
JWT_EXPIRES_IN=7d

# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Mock Behavior ────────────────────────────────────────────────────────
# Add a fixed delay (ms) to every response. Use the per-request `?scenario=slow`
# or `?scenario=very_slow` query parameter when you only need it sometimes.
MOCK_DELAY=0
