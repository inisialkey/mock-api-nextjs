            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products", "{{product_id}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"price\": 1799000,\n  \"stock\": 100\n}" }
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products", "{{product_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/notifications?page=1&limit=20",
              "host": ["{{base_url}}"], "path": ["notifications"],
              "query": [
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "20" },
                { "key": "type",    "value": "promo", "disabled": true },
                { "key": "is_read", "value": "false", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
