          ]
        },
        {
          "name": "Mark as read",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{base_url}}/notifications/{{notification_id}}/read", "host": ["{{base_url}}"], "path": ["notifications", "{{notification_id}}", "read"] }
          }
