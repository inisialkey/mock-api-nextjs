{
  "info": {
    "name": "MockApp API",
    "description": "Production-ready mock API for the MockApp mobile application. Import this collection together with the **MockApp (Local)** environment.\n\n## Quick start\n1. Import this collection AND the `postman_environment.json` file.\n2. Select the **MockApp (Local)** environment in the top-right.\n3. Run **Auth → Login (admin)** — the `access_token` and `refresh_token` are captured automatically by the test script.\n4. Every other request uses the saved token via the collection-level Bearer auth.\n\n## Edge cases\nAppend `?scenario=<name>` to any request:\n- `error` `validation` `unauthorized` `forbidden` `not_found` `maintenance` `rate_limit` `force_update` `empty` `slow` `very_slow` `timeout`\n\nSee `00-overview.md` and `openapi.yaml` in this repo for full spec.",
    "version": "1.2.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:3000/api", "type": "string" },
    { "key": "access_token",  "value": "",                          "type": "string" },
    { "key": "refresh_token", "value": "",                          "type": "string" },
    { "key": "user_id",       "value": "",                          "type": "string" },
    { "key": "product_id",    "value": "",                          "type": "string" },
    { "key": "room_id",       "value": "",                          "type": "string" },
    { "key": "notification_id","value": "",                         "type": "string" },
    { "key": "address_id",    "value": "",                          "type": "string" },
    { "key": "order_id",      "value": "",                          "type": "string" },
    { "key": "order_ref",     "value": "",                          "type": "string" },
    { "key": "app_version",   "value": "2.0.0",                     "type": "string" },
    { "key": "app_platform",  "value": "android",                   "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate a per-request X-Request-Id for traceability",
          "if (pm.request.headers.idx('X-Request-Id') === -1) {",
          "  pm.request.headers.add({ key: 'X-Request-Id', value: 'req_' + pm.variables.replaceIn('{{$guid}}') });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "X-App-Version",   "value": "{{app_version}}" },
              { "key": "X-App-Platform",  "value": "{{app_platform}}" }
            ],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Andi Wijaya\",\n  \"email\": \"andi+{{$timestamp}}@example.com\",\n  \"password\": \"secret123\",\n  \"phone\": \"+6281234567892\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('envelope.success = true', () => pm.expect(body.success).to.eql(true));",
                  "if (body.data && body.data.access_token) {",
                  "  pm.collectionVariables.set('access_token',  body.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "  pm.collectionVariables.set('user_id',       body.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "X-App-Version",   "value": "{{app_version}}" },
              { "key": "X-App-Platform",  "value": "{{app_platform}}" }
            ],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@mock.com\",\n  \"password\": \"password123\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('envelope.success = true', () => pm.expect(body.success).to.eql(true));",
                  "pm.test('data has tokens', () => {",
                  "  pm.expect(body.data).to.have.property('access_token');",
                  "  pm.expect(body.data).to.have.property('refresh_token');",
                  "});",
                  "pm.collectionVariables.set('access_token',  body.data.access_token);",
                  "pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "pm.collectionVariables.set('user_id',       body.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@mock.com\",\n  \"password\": \"password123\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.success) {",
                  "  pm.collectionVariables.set('access_token',  body.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "  pm.collectionVariables.set('user_id',       body.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — invalid credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@mock.com\",\n  \"password\": \"WRONG\"\n}" }
          }
        },
        {
          "name": "Login — validation error (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/auth/login?scenario=validation",
              "host": ["{{base_url}}"], "path": ["auth", "login"],
              "query": [{ "key": "scenario", "value": "validation" }]
            },
            "body": { "mode": "raw", "raw": "{ \"email\": \"\" }" }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.success) {",
                  "  pm.collectionVariables.set('access_token',  body.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('access_token',  '');",
                  "pm.collectionVariables.set('refresh_token', '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/users?page=1&limit=20",
              "host": ["{{base_url}}"], "path": ["users"],
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get user",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"+6281234567899\"\n}" }
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/products?page=1&limit=20&sort=created_at&order=desc",
              "host": ["{{base_url}}"], "path": ["products"],
              "query": [
                { "key": "page",      "value": "1" },
                { "key": "limit",     "value": "20" },
                { "key": "sort",      "value": "created_at" },
                { "key": "order",     "value": "desc" },
                { "key": "search",    "value": "", "disabled": true },
                { "key": "category",  "value": "electronics", "disabled": true },
                { "key": "min_price", "value": "100000", "disabled": true },
                { "key": "max_price", "value": "5000000", "disabled": true },
                { "key": "in_stock",  "value": "true", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.success && body.data && body.data.length) {",
                  "  pm.collectionVariables.set('product_id', body.data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List products — empty",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/products?scenario=empty",
              "host": ["{{base_url}}"], "path": ["products"],
              "query": [{ "key": "scenario", "value": "empty" }]
            }
          }
        },
        {
          "name": "List products — slow",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/products?scenario=slow",
              "host": ["{{base_url}}"], "path": ["products"],
              "query": [{ "key": "scenario", "value": "slow" }]
            }
          }
        },
        {
          "name": "Get product",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products", "{{product_id}}"] }
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
